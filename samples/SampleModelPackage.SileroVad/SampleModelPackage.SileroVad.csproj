<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <Description>Sample model package — snakers4/silero-vad (voice activity detection via ONNX).</Description>
  </PropertyGroup>
  <ItemGroup>
    <ProjectReference Include="..\..\src\ModelPackages\ModelPackages.csproj" />
    <PackageReference Include="MLNet.AudioInference.Onnx" Version="0.1.0-preview.2" />
  </ItemGroup>
  <ItemGroup>
    <EmbeddedResource Include="model-manifest.json" />
  </ItemGroup>
  <ItemGroup>
    <None Include="build\SampleModelPackage.SileroVad.props" Pack="true" PackagePath="build\" />
    <None Include="build\SampleModelPackage.SileroVad.targets" Pack="true" PackagePath="build\" />
  </ItemGroup>
</Project>
